experiments/EXECUTION_REPORT.md
experiments/ORDER_ROUNDTRIP_LOG.md
experiments/DOMAIN_PROBE_LOG.md
experiments/DRESS_REHEARSAL_REPORT.md

# Dev cruft.
.git
.idea
.venv
venv
__pycache__
*.pyc
.pytest_cache
.coverage
htmlcov
