# Copy to `.env` on the VM and fill in. .env is gitignored and NOT baked into the image.
#
# MEXC API credentials (the futures/contract trading key). The container injects these as
# env vars; both the live trader and the preflight/experiment scripts read them.
MEXC_API_KEY=
MEXC_SECRET_KEY=

# Live-trading safety gate. The trader REFUSES live mode unless this is exactly "1".
# Leave blank/0 while validating; set to 1 only when you intend to place real orders.
FRT_CONFIRM_LIVE=0

# Gates the real-order experiment scripts (roundtrip / rehearsal). Independent of the trader.
# Set to 1 only for the one-off live execution probes.
MEXC_ALLOW_LIVE_ORDERS=0
